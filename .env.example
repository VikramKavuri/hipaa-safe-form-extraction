# Copy to `.env` and adjust. All variables are optional; defaults are sane.
# Loaded automatically by pydantic-settings (prefix FORMEXTRACT_).

# Folder of forms to process (PDF/PNG/JPG/TIFF/BMP).
FORMEXTRACT_INPUT_FOLDER=data/sample

# Where to write the output CSV.
FORMEXTRACT_OUTPUT_CSV=outputs/extracted_firedrill_forms.csv

# Absolute path to the Tesseract binary. Leave unset if tesseract is on PATH.
# Windows example:
# FORMEXTRACT_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
FORMEXTRACT_TESSERACT_CMD=

# Ollama vision model tag (must be pulled: `ollama pull qwen2.5vl:7b`).
FORMEXTRACT_VLM_MODEL=qwen2.5vl:7b

# Rendering / preprocessing knobs.
FORMEXTRACT_PDF_RENDER_DPI=600
FORMEXTRACT_USE_CLAHE=true
FORMEXTRACT_DO_DESKEW=true
FORMEXTRACT_ENABLE_OSD_ORIENTATION=true

# Checkbox localization pass.
FORMEXTRACT_CHECKBOX_ENABLED=true
FORMEXTRACT_CHECKBOX_DEBUG=false
